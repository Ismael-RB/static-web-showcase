---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
---

<Layout title="Static Web Showcase">
	<!--
		--- Per-page part ---------------------------------------------
		Same <Hero /> component as every other page below. Only the
		props change: title, subtitle, CTA text/link and variant.
	-->
	<Hero
		title="Static Web Showcase"
		subtitle="A base template for static websites, built stage by stage: Astro, Tailwind, a shared design system, and reusable components."
		ctaText="See Página 1"
		ctaHref="/pagina-1"
		variant="accent"
	/>
</Layout>
