---
import '../styles/global.css';
import Hero from '../components/Hero.astro';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Página 3 · Static Web Showcase</title>
	</head>
	<body class="bg-background text-foreground font-sans">
		<nav class="flex justify-center gap-6 border-b border-border px-6 py-4 text-sm">
			<a href="/">Home</a>
			<a href="/pagina-1">Página 1</a>
			<a href="/pagina-2">Página 2</a>
			<a href="/pagina-3">Página 3</a>
		</nav>

		<!--
			--- Per-page part ---------------------------------------------
			Same <Hero /> component a third time: no ctaText/ctaHref at all,
			so the component renders without a button — proving the props
			are genuinely optional, not just re-styled per page.
		-->
		<Hero
			title="Real-time inventory, without the complexity"
			subtitle="This section has no call-to-action button — props like ctaText are optional, so pages can omit what they don't need."
		/>
	</body>
</html>
