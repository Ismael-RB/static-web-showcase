---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import CatalogCard from '../components/CatalogCard.astro';

// getCollection() reads every entry under src/content/catalog/,
// already validated against the schema in src/content.config.ts.
const items = await getCollection('catalog');
---

<Layout title="Catalog · Static Web Showcase">
	<section class="mx-auto max-w-5xl px-6 py-16">
		<h1 class="mb-2 text-3xl font-bold">Catalog</h1>
		<p class="mb-10 text-foreground/70">
			Example entries from the "catalog" content collection — placeholder data, real schema.
		</p>

		<div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
			{items.map((item) => <CatalogCard {...item.data} />)}
		</div>
	</section>
</Layout>
