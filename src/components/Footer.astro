---
// Reusable part: site-wide footer, rendered once from Layout so pages
// don't repeat it. Pure HTML/CSS — no client-side behavior needed.
const year = new Date().getFullYear();

const links = [
	{ href: "/catalog", label: "Catálogo" },
	{ href: "/contacto", label: "Contacto" },
];
---

<footer class="border-border text-foreground/70 border-t px-6 py-8 text-sm">
	<div class="mx-auto flex max-w-6xl flex-col items-center gap-4 sm:flex-row sm:justify-between">
		<p>Static Web Showcase — placeholder brand text.</p>
		<nav class="flex gap-6">
			{
				links.map((link) => (
					<a href={link.href} class="hover:text-accent">
						{link.label}
					</a>
				))
			}
		</nav>
		<p>&copy; {year} Static Web Showcase.</p>
	</div>
</footer>
