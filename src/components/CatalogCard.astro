---
// Reusable part: renders one catalog entry as a link to its detail page.
// The list page below just loops over collection entries and passes each
// one's `id` + `data` here — it never repeats this markup per item. The
// Carousel now lives only on the detail page, so this card just shows the
// first image as a static thumbnail.
interface Props {
	id: string;
	name: string;
	category: string;
	shortDescription: string;
	specs: string[];
	images: string[];
}

const { id, name, category, shortDescription, specs, images } = Astro.props;
---

<a
	href={`/catalog/${id}`}
	class="flex flex-col overflow-hidden rounded-lg border border-border transition hover:border-accent"
>
	<img src={images[0]} alt={name} class="h-48 w-full object-cover" />
	<div class="flex flex-col gap-2 p-5">
		<span class="text-xs font-medium uppercase tracking-wide text-accent">
			{category}
		</span>
		<h2 class="text-lg font-semibold">{name}</h2>
		<p class="text-sm text-foreground/70">{shortDescription}</p>
		<ul class="mt-2 flex flex-col gap-1 text-sm text-foreground/70">
			{specs.map((spec) => <li>• {spec}</li>)}
		</ul>
	</div>
</a>
